def run_rules(rules: list[dict], emails: list[dict]) -> list[dict]:
    """
    Main entry point. Send all rules + all emails to the
    enterprise LLM in a single /invoke call. Archive after.

    Args:
        rules:  list of {id, name, instruction} — active rules only
        emails: list of email dicts from mailbox_service

    Returns:
        list of decision dicts, one per email
    """
    if not rules:
        raise ValueError("No rules provided")
    if not emails:
        return []

    # Build the full prompt
    # Combine system instructions + email data into one message
    # because enterprise /invoke typically takes a single prompt string
    system_part = _build_system_prompt(rules)
    email_part  = _build_email_block(emails)
    full_prompt = f"{system_part}\n\nHere are the emails to classify:\n\n{email_part}"

    logger.info(
        f"Calling enterprise LLM: {len(emails)} emails, "
        f"{len(rules)} rules"
    )

    # Call LLM (invoke + archive handled inside _call_llm)
    response_text = _call_llm(full_prompt)

    # Parse JSON response
    # Strip markdown fences if LLM wraps output in them
    cleaned = response_text.strip()
    if cleaned.startswith('```'):
        cleaned = cleaned.split('\n', 1)[1].rsplit('```', 1)[0].strip()

    try:
        decisions = json.loads(cleaned)
    except json.JSONDecodeError as e:
        logger.error(f"LLM returned invalid JSON: {e}\nRaw: {response_text[:500]}")
        raise ValueError(f"LLM did not return valid JSON: {e}")

    logger.info(f"LLM returned {len(decisions)} decisions")
    return decisions
