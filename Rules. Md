import logging
from datetime import datetime, timedelta
from fastapi import APIRouter, HTTPException
from app.models.rule import RunRulesRequest
from app.services.rules_service import run_rules
from app.services.mailbox_service import get_emails, move_email
from app.config import settings

router = APIRouter(prefix='/rules', tags=['rules'])
logger = logging.getLogger(__name__)


@router.post('/run')
def run_rules_endpoint(body: RunRulesRequest):
    """
    Fetch emails for the date range, send all rules to the
    enterprise LLM in one invoke call, move emails, return results.

    Steps:
      1. Fetch emails from mailbox
      2. Filter to the requested date range
      3. Send to LLM via rules_service.run_rules()
         (invoke → parse → archive handled inside the service)
      4. For each 'moved' decision, call move_email()
      5. Return full results to the frontend
    """
    if not body.rules:
        raise HTTPException(status_code=400, detail='No rules provided')

    # Step 1: fetch emails
    try:
        mailbox = body.mailbox or settings.PERSONAL_MAILBOX
        all_emails = get_emails(
            is_shared=body.is_shared,
            mailbox=mailbox,
            filter_type='all',
            limit=200,
        )
    except Exception as e:
        raise HTTPException(
            status_code=503,
            detail=f"Cannot fetch emails from mailbox: {str(e)}"
        )

    # Step 2: filter by date range
    try:
        start_dt = datetime.strptime(body.start_date, '%Y-%m-%d')
        end_dt   = datetime.strptime(body.end_date,   '%Y-%m-%d') \
                   + timedelta(days=1)
    except ValueError:
        raise HTTPException(
            status_code=400,
            detail='Invalid date format — use YYYY-MM-DD'
        )

    filtered = [
        e for e in all_emails
        if e.get('timestamp', '') >= start_dt.isoformat()[:10]
        and e.get('timestamp', '') <= end_dt.isoformat()[:10]
    ]

    logger.info(
        f"{len(all_emails)} total emails, "
        f"{len(filtered)} in range {body.start_date} → {body.end_date}"
    )

    if not filtered:
        return {
            'total_emails':    len(all_emails),
            'emails_in_range': 0,
            'moved':           0,
            'no_match':        0,
            'errors':          0,
            'results':         [],
            'run_at':          datetime.utcnow().isoformat(),
        }

    # Step 3: call enterprise LLM
    # run_rules() handles: invoke → parse JSON → archive
    rules_dicts = [r.dict() for r in body.rules]
    try:
        decisions = run_rules(rules=rules_dicts, emails=filtered)
    except Exception as e:
        logger.error(f"LLM call failed: {e}")
        raise HTTPException(
            status_code=500,
            detail=f"LLM processing failed: {str(e)}"
        )

    # Step 4: move emails + build results
    email_map = {e['id']: e for e in filtered}
    results   = []

    for decision in decisions:
        email_id = decision.get('email_id', '')
        email    = email_map.get(email_id, {})
        status   = decision.get('status', 'no_match')
        error_msg = None

        if status == 'moved' and decision.get('folder'):
            try:
                move_email(
                    is_shared=body.is_shared,
                    mailbox=mailbox,
                    email_id=email_id,
                    destination_folder=decision['folder'],
                )
            except Exception as e:
                error_msg = str(e)
                status    = 'error'
                logger.warning(
                    f"Could not move email {email_id} "
                    f"to '{decision['folder']}': {e}"
                )

        results.append({
            'emailId':         email_id,
            'subject':         email.get('subject', ''),
            'from':            email.get('sender_email', ''),
            'matchedRuleId':   decision.get('rule_id', ''),
            'matchedRuleName': decision.get('rule_name', ''),
            'folder':          decision.get('folder', ''),
            'confidence':      decision.get('confidence', 'low'),
            'reasoning':       decision.get('reasoning', ''),
            'status':          status,
            'errorMessage':    error_msg,
        })

    moved    = sum(1 for r in results if r['status'] == 'moved')
    no_match = sum(1 for r in results if r['status'] == 'no_match')
    errors   = sum(1 for r in results if r['status'] == 'error')

    logger.info(
        f"Rules run complete: {moved} moved, "
        f"{no_match} no match, {errors} errors"
    )

    return {
        'total_emails':    len(all_emails),
        'emails_in_range': len(filtered),
        'moved':           moved,
        'no_match':        no_match,
        'errors':          errors,
        'results':         results,
        'run_at':          datetime.utcnow().isoformat(),
    }
```


