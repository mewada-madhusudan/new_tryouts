def _build_system_prompt(rules: list[dict]) -> str:
    """
    Build the instruction block that tells the LLM how to classify
    emails. This becomes the system/instruction part of the prompt.
    """
    rules_text = '\n'.join(
        f"{i+1}. [{r['name']}]: {r['instruction']}"
        for i, r in enumerate(rules)
    )
    return f"""You are an email organiser. Apply these rules in order:

{rules_text}

For each email, apply the FIRST matching rule only.
If no rule matches, set status to "no_match".

Respond ONLY with a valid JSON array — no markdown, no explanation outside the array.
Each element must have exactly these fields:
  "email_id"   : the email ID I gave you (string)
  "rule_id"    : the matching rule number as a string, empty string if no match
  "rule_name"  : the matching rule name, empty string if no match
  "folder"     : destination folder extracted from the rule, empty string if no match
  "confidence" : one of "high", "medium", "low"
  "reasoning"  : one or two sentences explaining the decision
  "status"     : one of "moved", "no_match", "error"
"""


def _build_email_block(emails: list[dict]) -> str:
    """Format emails as the user message content."""
    lines = []
    for email in emails:
        lines.append(
            f"EMAIL_ID: {email.get('id', '')}\n"
            f"From: {email.get('sender_name', '')} <{email.get('sender_email', '')}>\n"
            f"Subject: {email.get('subject', '')}\n"
            f"Preview: {email.get('preview', '')[:300]}\n"
            f"---"
        )
    return '\n'.join(lines)


