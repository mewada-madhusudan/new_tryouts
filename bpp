```python
"""
Log Service — reads/writes JSON log files from data/logs/

Each log file is named {run_id}.json and contains:
{
  "run_id": "...",
  "task_id": "...",
  "task_name": "...",
  "task_type": "...",
  "status": "success|failed|skipped",
  "started_at": "ISO datetime",
  "completed_at": "ISO datetime",
  "duration_ms": 1240,
  "entries": [
    {"timestamp": "...", "level": "INFO|WARNING|ERROR", "message": "..."}
  ]
}
"""
import json
import logging
from pathlib import Path
from datetime import datetime
from typing import Optional
from app.config import settings

logger = logging.getLogger(__name__)


def _log_dir() -> Path:
    p = Path(settings.LOG_DIR)
    p.mkdir(parents=True, exist_ok=True)
    return p


def list_logs(
    status:    Optional[str] = None,
    search:    Optional[str] = None,
    start:     Optional[str] = None,
    end:       Optional[str] = None,
    page:      int = 1,
    page_size: int = 15,
) -> dict:
    """
    List log summaries (no entries array — metadata only).
    Returns paginated results.
    """
    log_files = sorted(
        _log_dir().glob('*.json'),
        key=lambda f: f.stat().st_mtime,
        reverse=True,
    )

    # Skip the app.log file if it ends up here
    log_files = [f for f in log_files if f.stem != 'app']

    results = []
    for f in log_files:
        try:
            data = json.loads(f.read_text())
        except Exception:
            continue

        # Filters
        if status and status.lower() != 'all':
            if data.get('status', '').lower() != status.lower():
                continue

        if search:
            if search.lower() not in data.get('task_name', '').lower():
                continue

        if start:
            try:
                if data.get('started_at', '') < start:
                    continue
            except Exception:
                pass

        if end:
            try:
                if data.get('started_at', '') > end:
                    continue
            except Exception:
                pass

        # Summary (no entries)
        results.append({
            'id':          data.get('run_id', f.stem),
            'taskName':    data.get('task_name', ''),
            'taskType':    data.get('task_type', ''),
            'timestamp':   data.get('started_at', ''),
            'duration':    f"{data.get('duration_ms', 0) / 1000:.1f}s",
            'status':      data.get('status', 'unknown').capitalize(),
        })

    total = len(results)
    start_idx = (page - 1) * page_size
    end_idx   = start_idx + page_size

    return {
        'logs':      results[start_idx:end_idx],
        'total':     total,
        'page':      page,
        'page_size': page_size,
        'pages':     (total + page_size - 1) // page_size,
    }


def get_log(run_id: str) -> Optional[dict]:
    """Return full log including entries array."""
    log_file = _log_dir() / f"{run_id}.json"
    if not log_file.exists():
        return None
    return json.loads(log_file.read_text())


def get_summary() -> dict:
    """Return total / successful / failed counts."""
    log_files = list(_log_dir().glob('*.json'))
    log_files = [f for f in log_files if f.stem != 'app']

    total = successful = failed = skipped = 0
    for f in log_files:
        try:
            data = json.loads(f.read_text())
            status = data.get('status', '').lower()
            total += 1
            if status == 'success':    successful += 1
            elif status == 'failed':   failed += 1
            elif status == 'skipped':  skipped += 1
        except Exception:
            pass

    return {
        'total':      total,
        'successful': successful,
        'failed':     failed,
        'skipped':    skipped,
    }


def export_logs(start: Optional[str] = None, end: Optional[str] = None) -> list[dict]:
    """Return full logs for download."""
    log_files = list(_log_dir().glob('*.json'))
    log_files = [f for f in log_files if f.stem != 'app']
    results = []
    for f in log_files:
        try:
            data = json.loads(f.read_text())
            if start and data.get('started_at', '') < start:
                continue
            if end and data.get('started_at', '') > end:
                continue
            results.append(data)
        except Exception:
            pass
    return sorted(results, key=lambda d: d.get('started_at', ''), reverse=True)
