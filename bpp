    subject_line:        task.config.subject_line ?? '',
    to_stakeholders:     task.config.to_stakeholders ?? '',
    cc_stakeholders:     task.config.cc_stakeholders ?? '',
    attachment_folder_path: task.config.attachment_folder_path ?? '',
    attachment_file_name:   task.config.attachment_file_name ?? '',
    email_body_source:   task.config.email_body_source ?? 'docx',
    email_body_path:     task.config.email_body_path ?? '',
    draft_or_send:       task.config.draft_or_send ?? 'draft',
    voting_option:       task.config.voting_option ?? '',
    reminder_body_path:  task.config.reminder_body_path ?? '',
    find_replace_pairs:  task.config.find_replace_pairs ?? [],
    partial_subject:     task.config.partial_subject ?? false,
    screening_folder:    task.config.screening_folder ?? '',
    start_date:          task.config.start_date ?? '',
    end_date:            task.config.end_date ?? '',
    due_date:            task.config.due_date ?? '',
    to_tracking:         task.config.to_tracking ?? '',
    save_email:          task.config.save_email ?? false,
    save_both:           task.config.save_both ?? 'both',
    save_as:             task.config.save_as ?? 'pdf',
    download_attachment: task.config.download_attachment ?? false,
    all_or_specific:     task.config.all_or_specific ?? 'all',
    file_type:           task.config.file_type ?? '',
    extract_zip:         task.config.extract_zip ?? false,
  }
}
```

Add to component state:
```tsx
const [editState, editDispatch] = useReducer(editReducer, task ? taskToEditState(task) : {} as EditState)
const [hasChanges, setHasChanges] = useState(false)
const update = (patch: Partial<EditState>) => {
  editDispatch(patch)
  setHasChanges(true)
}
```

When mode changes from view to edit, reset editState from task:
```tsx
useEffect(() => {
  if (mode === 'edit' && task) {
    editDispatch(taskToEditState(task))
    setHasChanges(false)
  }
}, [mode, task])
```

