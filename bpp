      cc_stakeholders:       editState.cc_stakeholders,
      attachment_folder_path:editState.attachment_folder_path,
      attachment_file_name:  editState.attachment_file_name,
      email_body_source:     editState.email_body_source,
      email_body_path:       editState.email_body_path,
      draft_or_send:         editState.draft_or_send,
