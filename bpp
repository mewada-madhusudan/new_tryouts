"""
Mailbox Service — uses corporate Graph API proxy.
Base URL: https://o365-graph-proxy-ms6.gaiacloud.jpmchase.net

Personal mailbox: GET /me/messages
Shared mailbox:   GET /users/{mailbox_address}/messages

Authentication: reused from src/helpers/fetch_token.py
"""
import sys
import logging
from pathlib import Path
from typing import Optional
import httpx

sys.path.insert(0, str(Path(__file__).parent.parent.parent / 'src'))

logger = logging.getLogger(__name__)

GRAPH_PROXY_BASE = 'https://o365-graph-proxy-ms6.gaiacloud.jpmchase.net'


def _get_headers() -> dict:
    """
    Get auth headers by reusing fetch_token.py from existing code.
    READ src/helpers/fetch_token.py first to confirm the exact
    function to call and what it returns.

    If it returns a token string:
        token = fetch_token()
        return {'Authorization': f'Bearer {token}'}

    If it returns a headers dict already:
        return fetch_token()

    Adjust the implementation below based on what you find.
    """
    from helpers.fetch_token import fetch_token   # adjust name if different
    token = fetch_token()
    if isinstance(token, dict):
        return token
    return {
        'Authorization': f'Bearer {token}',
        'Content-Type': 'application/json',
    }


def _email_to_dict(msg: dict) -> dict:
    """
    Normalise a Graph API message object into our standard format.
    Graph API returns messages with these fields:
      id, subject, bodyPreview, body.content,
      from.emailAddress.name, from.emailAddress.address,
      toRecipients[].emailAddress.address,
      receivedDateTime, isRead, hasAttachments
    """
    sender = msg.get('from', {}).get('emailAddress', {})
    return {
        'id':          msg.get('id', ''),
        'subject':     msg.get('subject', '(No Subject)'),
        'sender_name': sender.get('name', ''),
        'sender_email':sender.get('address', ''),
        'to':          ', '.join(
            r.get('emailAddress', {}).get('address', '')
            for r in msg.get('toRecipients', [])
        ),
        'preview':     msg.get('bodyPreview', ''),
        'body':        msg.get('body', {}).get('content', ''),
        'timestamp':   msg.get('receivedDateTime', ''),
        'is_read':     msg.get('isRead', True),
        'has_attachments': msg.get('hasAttachments', False),
    }


def get_emails(
    is_shared: bool,
    mailbox: str,
    filter_type: str = 'all',
    limit: int = 50,
) -> list[dict]:
    """
    Fetch emails from the corporate Graph API proxy.

    Args:
        is_shared:   True = shared mailbox (/users/{mailbox}/messages)
                     False = personal mailbox (/me/messages)
        mailbox:     Email address (used only when is_shared=True)
        filter_type: 'all' or 'unread'
        limit:       Max emails to return (default 50)

    Returns:
        List of normalised email dicts
    """
    headers = _get_headers()

    if is_shared:
        endpoint = f'{GRAPH_PROXY_BASE}/users/{mailbox}/messages'
    else:
        endpoint = f'{GRAPH_PROXY_BASE}/me/messages'

    params = {
        '$top': limit,
        '$orderby': 'receivedDateTime desc',
        '$select': (
            'id,subject,bodyPreview,body,from,toRecipients,'
            'receivedDateTime,isRead,hasAttachments'
        ),
    }

    if filter_type == 'unread':
        params['$filter'] = 'isRead eq false'

    try:
        response = httpx.get(
            endpoint,
            headers=headers,
            params=params,
            timeout=15.0,
            verify=False,   # corporate proxy may use internal cert
        )
        response.raise_for_status()
        data = response.json()
        return [_email_to_dict(m) for m in data.get('value', [])]

    except httpx.HTTPStatusError as e:
        logger.error(f"Graph API error {e.response.status_code}: {e.response.text}")
        raise
    except httpx.RequestError as e:
        logger.error(f"Network error connecting to proxy: {e}")
        raise


def get_email_by_id(
    is_shared: bool,
    mailbox: str,
    email_id: str,
) -> dict:
    """Fetch a single email by ID with full body."""
    headers = _get_headers()

    if is_shared:
        endpoint = f'{GRAPH_PROXY_BASE}/users/{mailbox}/messages/{email_id}'
    else:
        endpoint = f'{GRAPH_PROXY_BASE}/me/messages/{email_id}'

    params = {
        '$select': (
            'id,subject,body,from,toRecipients,'
            'receivedDateTime,isRead,hasAttachments,attachments'
        ),
    }

    response = httpx.get(
        endpoint, headers=headers, params=params,
        timeout=15.0, verify=False
    )
    response.raise_for_status()
    return _email_to_dict(response.json())


def get_email_count(is_shared: bool, mailbox: str) -> dict:
    """Return total and unread counts."""
    all_emails = get_emails(is_shared, mailbox, 'all', limit=1000)
    unread = [e for e in all_emails if not e['is_read']]
    return {'total': len(all_emails), 'unread_count': len(unread)}


def move_email(
    is_shared: bool,
    mailbox: str,
    email_id: str,
    destination_folder: str,
) -> bool:
    """Move email to a folder (e.g. 'archive', 'deleteditems')."""
    headers = _get_headers()

    if is_shared:
        endpoint = f'{GRAPH_PROXY_BASE}/users/{mailbox}/messages/{email_id}/move'
    else:
        endpoint = f'{GRAPH_PROXY_BASE}/me/messages/{email_id}/move'

    response = httpx.post(
        endpoint,
        headers=headers,
        json={'destinationId': destination_folder},
        timeout=15.0,
        verify=False,
    )
    return response.status_code in (200, 201)


def delete_email(is_shared: bool, mailbox: str, email_id: str) -> bool:
    """Move email to Deleted Items."""
    return move_email(is_shared, mailbox, email_id, 'deleteditems')


def archive_email(is_shared: bool, mailbox: str, email_id: str) -> bool:
    """Move email to Archive."""
    return move_email(is_shared, mailbox, email_id, 'archive')
