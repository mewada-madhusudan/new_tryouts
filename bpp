        if first:
            ws.title = name
        ws.append(list(columns.keys()))
        return ws

    _add_sheet(wb, 'Draft', DRAFT_COLUMNS, first=True)
    _add_sheet(wb, 'Email Tracking', TRACKING_COLUMNS)
    _add_sheet(wb, 'Download', DOWNLOAD_COLUMNS)

    buf = io.BytesIO()
    wb.save(buf)
    buf.seek(0)

    return Response(
        content=buf.read(),
        media_type='application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
        headers={
            'Content-Disposition': 'attachment; filename="task_template.xlsx"'
        },
    )


# ── POST /api/import-export/upload ───────────────────────

@router.post('/upload')
async def upload_file(file: UploadFile = File(...)):
    """Import tasks from the uploaded Excel file."""
    if not file.filename.endswith('.xlsx'):
        raise HTTPException(status_code=400, detail='Only .xlsx files are accepted')

    content = await file.read()
    try:
        wb = openpyxl.load_workbook(io.BytesIO(content))
    except Exception as e:
        raise HTTPException(status_code=400, detail=f'Invalid Excel file: {e}')

    all_tasks, all_errors = [], []

    sheet_map = {
        'Draft':          (DRAFT_COLUMNS,    'draft_send'),
        'Email Tracking': (TRACKING_COLUMNS, 'email_tracking'),
        'Download':       (DOWNLOAD_COLUMNS, 'download'),
    }

    for sheet_name, (col_map, task_type) in sheet_map.items():
        if sheet_name not in wb.sheetnames:
            all_errors.append(f"Sheet '{sheet_name}' not found — skipped")
            continue
        tasks, errors = _parse_sheet(wb[sheet_name], col_map, task_type)
        all_tasks.extend(tasks)
        all_errors.extend(errors)

    imported = 0
    existing = {t['process_name']: t for t in load_tasks()}

    for task in all_tasks:
        if task['process_name'] in existing:
            all_errors.append(
                f"'{task['process_name']}' already exists — skipped (no overwrite)"
            )
        else:
            create_task(task)
            imported += 1

    return {
        'imported': imported,
        'skipped':  len(all_tasks) - imported,
        'errors':   all_errors,
    }


# ── GET /api/import-export/meta ──────────────────────────

@router.get('/meta')
def get_meta():
    return _load_meta()


# ── POST /api/import-export/export ───────────────────────

@router.post('/export')
def export_data(
    format:        str  = Query('json', regex='^(json|excel)$'),
    include_tasks: bool = Query(True),
    include_logs:  bool = Query(True),
):
    tasks = load_tasks() if include_tasks else []

    from app.services.log_service import export_logs
    logs = export_logs() if include_logs else []

    _save_meta({'last_exported_at': datetime.utcnow().isoformat()})

    if format == 'excel':
        wb = openpyxl.Workbook()
        ws_tasks = wb.active
        ws_tasks.title = 'Tasks'
        if tasks:
            ws_tasks.append(list(tasks[0].keys()))
            for t in tasks:
                ws_tasks.append([str(v) for v in t.values()])

        ws_logs = wb.create_sheet('Logs')
        if logs:
            ws_logs.append(['run_id', 'task_name', 'status',
                            'started_at', 'duration_ms'])
            for lg in logs:
                ws_logs.append([
                    lg.get('run_id', ''), lg.get('task_name', ''),
                    lg.get('status', ''), lg.get('started_at', ''),
                    lg.get('duration_ms', 0),
                ])
        buf = io.BytesIO()
        wb.save(buf)
        buf.seek(0)
        return Response(
            content=buf.read(),
            media_type='application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
            headers={'Content-Disposition': 'attachment; filename="export.xlsx"'},
        )

    # JSON format
    payload = {'tasks': tasks, 'logs': logs,
               'exported_at': datetime.utcnow().isoformat()}
    return Response(
        content=json.dumps(payload, indent=2),
        media_type='application/json',
        headers={'Content-Disposition': 'attachment; filename="export.json"'},
    )
