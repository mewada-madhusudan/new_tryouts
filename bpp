"""
Task Executor — wraps existing src/workers/* without modifying them.

IMPORTANT: Do not import PyQt, tkinter, or any GUI library here.
If a worker file has GUI imports at the top, we handle that below
using importlib to load only what we need.
"""
import sys
import io
import json
import logging
from uuid import uuid4
from datetime import datetime
from pathlib import Path
from typing import Any

# Add src/ to path so we can import existing helpers
sys.path.insert(0, str(Path(__file__).parent.parent.parent / 'src'))

logger = logging.getLogger(__name__)


class TaskExecutor:
    """
    Wraps the existing worker functions from src/workers/*.
    Does NOT modify any existing code.
    Captures stdout/print output as log entries.
    Writes a structured JSON log file after each run.
    """

    def __init__(self, task: dict, log_dir: str = 'data/logs'):
        self.task = task
        self.log_dir = Path(log_dir)
        self.log_dir.mkdir(parents=True, exist_ok=True)
        self.run_id = str(uuid4())
        self.started_at = datetime.utcnow()
        self.log_entries: list[dict] = []

    # ----------------------------------------------------------
    # Public method
    # ----------------------------------------------------------

    def run(self) -> dict:
        """Execute the task. Returns an ExecutionResult dict."""
        self._log('INFO', f"Starting task: {self.task.get('process_name', 'Unknown')}")
        self._log('INFO', f"Task type: {self.task.get('task_type', 'unknown')}")
        self._log('INFO', f"Mailbox: {self.task.get('mailbox', 'not set')}")

        status = 'success'
        try:
            self._dispatch()
            self._log('INFO', 'Task completed successfully')
        except Exception as e:
            self._log('ERROR', f"Task failed: {type(e).__name__}: {str(e)}")
            status = 'failed'
            logger.exception(f"Task {self.run_id} failed")

        completed_at = datetime.utcnow()
        duration_ms = int(
            (completed_at - self.started_at).total_seconds() * 1000
        )

        result = {
            'run_id':       self.run_id,
            'task_id':      self.task.get('id', 'unknown'),
            'task_name':    self.task.get('process_name', 'Unknown'),
            'task_type':    self.task.get('task_type', 'unknown'),
            'status':       status,
            'started_at':   self.started_at.isoformat(),
            'completed_at': completed_at.isoformat(),
            'duration_ms':  duration_ms,
            'entries':      self.log_entries,
        }

        self._write_log(result)
        self._update_last_run()
        return result

    # ----------------------------------------------------------
    # Dispatch to correct worker
    # ----------------------------------------------------------

    def _dispatch(self):
        task_type = self.task.get('task_type')
        is_shared = self.task.get('is_shared_mailbox', False)

        self._log('INFO',
            f"Routing to {'shared' if is_shared else 'personal'} "
            f"mailbox handler"
        )

        # Build the args dict that the existing workers expect.
        # READ src/email_manager.py to confirm the exact key names
        # and pass them here. The structure below mirrors what
        # email_manager.py passes — adjust based on B6 analysis.
        config = self.task.get('config', {})
        worker_args = self._build_worker_args(config)

        if task_type == 'draft_send':
            self._run_with_capture(self._call_draft, worker_args, is_shared)
        elif task_type == 'reminder':
            self._run_with_capture(self._call_reminder, worker_args, is_shared)
        elif task_type == 'email_tracking':
            self._run_with_capture(self._call_tracking, worker_args, is_shared)
        elif task_type == 'download':
            self._run_with_capture(self._call_download, worker_args, is_shared)
        else:
            raise ValueError(f"Unknown task type: {task_type}")

    def _build_worker_args(self, config: dict) -> dict:
        """
