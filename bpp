    # ----------------------------------------------------------
    # Worker callers — adjust function names and args
    # based on B6 analysis of actual worker signatures
    # ----------------------------------------------------------

    def _call_draft(self, args: dict, is_shared: bool):
        """
        Call the draft/send worker.
        READ src/workers/draft_mail.py to confirm:
          - exact function name to call
          - exact arguments it expects
          - whether is_shared changes which module to import

        Template (adjust based on B6 analysis):
        """
        if is_shared:
            from shared_routes.draft_mail import main as run_draft
        else:
            from personal_routes.draft_mail import main as run_draft
        run_draft(args)

    def _call_reminder(self, args: dict, is_shared: bool):
        if is_shared:
            from shared_routes.reminder import main as run_reminder
        else:
            from personal_routes.reminder import main as run_reminder
        run_reminder(args)

    def _call_tracking(self, args: dict, is_shared: bool):
        if is_shared:
            from shared_routes.track_mail import main as run_tracking
        else:
            from personal_routes.track_mail import main as run_tracking
        run_tracking(args)

    def _call_download(self, args: dict, is_shared: bool):
        if is_shared:
            from shared_routes.download_attachments import main as run_download
        else:
            from personal_routes.download_attachments import main as run_download
        run_download(args)

    # ----------------------------------------------------------
    # Capture stdout from worker (workers use print() for logging)
    # ----------------------------------------------------------

    def _run_with_capture(self, caller, args: dict, is_shared: bool):
        """Capture any print() output from the existing workers."""
        old_stdout = sys.stdout
        sys.stdout = buffer = io.StringIO()
        try:
            caller(args, is_shared)
        finally:
            sys.stdout = old_stdout
            output = buffer.getvalue()

        # Convert captured print lines to log entries
        for line in output.splitlines():
            line = line.strip()
            if not line:
                continue
            if any(w in line.upper() for w in ['ERROR', 'FAIL', 'EXCEPTION']):
                self._log('ERROR', line)
            elif any(w in line.upper() for w in ['WARN', 'WARNING']):
                self._log('WARNING', line)
            else:
                self._log('INFO', line)

    # ----------------------------------------------------------
    # Logging helpers
    # ----------------------------------------------------------

    def _log(self, level: str, message: str):
        entry = {
            'timestamp': datetime.utcnow().isoformat(),
            'level':     level,
            'message':   message,
        }
        self.log_entries.append(entry)
        getattr(logger, level.lower(), logger.info)(message)

    def _write_log(self, result: dict):
        log_file = self.log_dir / f"{self.run_id}.json"
        log_file.write_text(json.dumps(result, indent=2))
        self._log('INFO', f"Log written to {log_file}")

    def _update_last_run(self):
        """Update last_run_at in data/tasks.json for this task."""
        from app.services.task_store import get_task_by_id, update_task
        try:
            task_id = self.task.get('id')
            if task_id:
                update_task(task_id, {'last_run_at': datetime.utcnow().isoformat()})
        except Exception as e:
            logger.warning(f"Could not update last_run_at: {e}")
