Write app/tasks/scheduler.py

This module:
1. Starts APScheduler on FastAPI app startup
2. Registers all enabled non-adhoc tasks as scheduled jobs
3. Exposes trigger_now() for the Run button in the UI
4. Reacts to task enable/disable/create/delete events

```python
"""
Scheduler — APScheduler wrapping the TaskExecutor.

Jobs run in background threads so the API stays responsive.
Each job calls TaskExecutor(task).run() and logs the result.
"""
import logging
import threading
from datetime import datetime
from apscheduler.schedulers.background import BackgroundScheduler
from apscheduler.triggers.interval import IntervalTrigger
from apscheduler.triggers.cron import CronTrigger

logger = logging.getLogger(__name__)

_scheduler = BackgroundScheduler(timezone='UTC')
_run_results: dict[str, dict] = {}   # run_id → result (in-memory cache)


# ── Job function ──────────────────────────────────────────

def _execute_task(task: dict):
    """Called by APScheduler in a background thread."""
    from app.tasks.executor import TaskExecutor
    executor = TaskExecutor(task)
    try:
        result = executor.run()
        _run_results[result['run_id']] = result
        logger.info(
            f"Task '{task['process_name']}' finished "
            f"with status={result['status']} "
            f"run_id={result['run_id']}"
        )
    except Exception as e:
        logger.error(f"Scheduler job crashed for task {task.get('id')}: {e}")


# ── Scheduler lifecycle ───────────────────────────────────

def start():
    """Call this on FastAPI app startup."""
    from app.services.task_store import load_tasks
    tasks = load_tasks()
    enabled = [t for t in tasks if t.get('enabled', True)]
    for task in enabled:
        _register(task)
    _scheduler.start()
    logger.info(f"Scheduler started — {len(enabled)} tasks registered")


def stop():
    """Call this on FastAPI app shutdown."""
    if _scheduler.running:
        _scheduler.shutdown(wait=False)
        logger.info("Scheduler stopped")


# ── Task registration ─────────────────────────────────────

def _make_trigger(task: dict):
    """
    Build the APScheduler trigger from task schedule_type.
    schedule_type values (match what the frontend sends):
      every15   → IntervalTrigger(minutes=15)
      every1h   → IntervalTrigger(hours=1)
      daily     → CronTrigger at task['daily_time'] (HH:MM string)
      adhoc     → None (never auto-scheduled)
    """
    schedule = task.get('schedule_type', 'adhoc')

    if schedule == 'every15':
        return IntervalTrigger(minutes=15)
    elif schedule == 'every1h':
        return IntervalTrigger(hours=1)
    elif schedule == 'daily':
        time_str = task.get('daily_time', '08:00')
        try:
            hour, minute = time_str.split(':')
            return CronTrigger(hour=int(hour), minute=int(minute))
        except Exception:
            logger.warning(f"Invalid daily_time '{time_str}' — defaulting to 08:00")
            return CronTrigger(hour=8, minute=0)
    else:
        return None   # adhoc — do not register


def _register(task: dict):
    """Register a task as an APScheduler job."""
    trigger = _make_trigger(task)
    if trigger is None:
        return   # adhoc tasks are not scheduled

    job_id = f"task_{task['id']}"

    # Remove existing job if present (idempotent)
    if _scheduler.get_job(job_id):
        _scheduler.remove_job(job_id)

    _scheduler.add_job(
        func=_execute_task,
        trigger=trigger,
        args=[task],
        id=job_id,
        name=task.get('process_name', job_id),
        replace_existing=True,
        misfire_grace_time=60,
    )
    logger.info(
        f"Registered job '{task['process_name']}' "
        f"({task.get('schedule_type')}) id={job_id}"
    )


# ── Public API called by routers ──────────────────────────

def register_task(task: dict):
    """Call when a new task is created or re-enabled."""
    _register(task)


def unregister_task(task_id: str):
    """Call when a task is deleted or disabled."""
    job_id = f"task_{task_id}"
    if _scheduler.get_job(job_id):
        _scheduler.remove_job(job_id)
        logger.info(f"Unregistered job {job_id}")


def trigger_now(task: dict) -> str:
    """
    Run a task immediately in a background thread.
    Returns the run_id so the client can poll for results.
    Called by POST /api/tasks/{id}/run
    """
    run_id_holder = {'run_id': None}

    def _run():
        from app.tasks.executor import TaskExecutor
        executor = TaskExecutor(task)
        result = executor.run()
        _run_results[result['run_id']] = result
        run_id_holder['run_id'] = result['run_id']

    thread = threading.Thread(target=_run, daemon=True)
    thread.start()

    # Return a provisional run_id immediately
    # The actual run_id will be in the log file
    import uuid
    provisional = str(uuid.uuid4())
    return provisional


def get_scheduler_status() -> dict:
    """Return scheduler status for /api/health endpoint."""
    return {
        'running':   _scheduler.running,
        'job_count': len(_scheduler.get_jobs()),
        'jobs':      [
            {
                'id':       j.id,
                'name':     j.name,
                'next_run': j.next_run_time.isoformat() if j.next_run_time else None,
            }
            for j in _scheduler.get_jobs()
        ],
    }
```

