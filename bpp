            'Draft/Send':           config.get('draft_or_send', 'draft'),
            'Voting_Option':        config.get('voting_option', ''),

            # Find/Replace
            'Find_One':    config.get('find_replace_pairs', [{}])[0].get('find', '') if len(config.get('find_replace_pairs', [])) > 0 else '',
            'Replace_One': config.get('find_replace_pairs', [{}])[0].get('replace', '') if len(config.get('find_replace_pairs', [])) > 0 else '',
