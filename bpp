def update_task(task_id: str, updates: dict) -> dict:
    """
    Merge updates into an existing task.
    If updates contains a 'config' key, merge config
    fields individually rather than replacing the whole config.
    """
    tasks = load_tasks()
    for i, task in enumerate(tasks):
        if task.get('id') == task_id:
            # Deep merge config if provided
            if 'config' in updates and 'config' in task:
                merged_config = {**task['config'], **updates['config']}
                updates = {**updates, 'config': merged_config}
            tasks[i] = {**task, **updates}
            save_tasks(tasks)
            return tasks[i]
    raise ValueError(f"Task {task_id} not found")
