from app.models.task import TaskUpdateRequest
from datetime import datetime

@router.patch('/{task_id}')
def update_task_endpoint(task_id: str, body: TaskUpdateRequest):
    """
    Partial update a task. Only fields present in the request
    body are updated. updated_at is always refreshed.

    Called by the TaskViewModal save handler.
    Also reregisters the task in the scheduler if the
    schedule_type or enabled status changed.
    """
    existing = get_task_by_id(task_id)
    if not existing:
        raise HTTPException(status_code=404, detail='Task not found')

    # Build update dict — only include fields that were sent
    updates = body.dict(exclude_none=True)
    updates['updated_at'] = datetime.utcnow().isoformat()

    updated = update_task(task_id, updates)

    # Re-register in scheduler if schedule or enabled changed
    schedule_changed = 'schedule_type' in updates or 'daily_time' in updates
    enabled_changed  = 'enabled' in updates

    if schedule_changed or enabled_changed:
        from app.tasks.scheduler import register_task, unregister_task
        unregister_task(task_id)
        if updated.get('enabled', True):
            register_task(updated)

    return updated
