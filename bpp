--- TYPES ---

Create src/components/TaskViewModal/types.ts:

```ts
export type TaskType = 'draft_send' | 'reminder' | 'email_tracking' | 'download' | 'calendar'

export interface FindReplacePair {
  find: string
  replace: string
}

export interface TaskConfig {
  subject_line?: string
  to_stakeholders?: string
  cc_stakeholders?: string
  attachment_folder_path?: string
  attachment_file_name?: string
  email_body_source?: string
  email_body_path?: string
  draft_or_send?: string
  voting_option?: string
  reminder_body_path?: string
  find_replace_pairs?: FindReplacePair[]
  partial_subject?: boolean
  screening_folder?: string
  start_date?: string
  end_date?: string
  due_date?: string
  to_tracking?: string
  save_email?: boolean
  save_both?: string
  save_as?: string
  download_attachment?: boolean
  all_or_specific?: string
  file_type?: string
  extract_zip?: boolean
}

export interface Task {
  id: string
  process_name: string
  task_type: TaskType
  schedule_type: string
  daily_time?: string
  is_shared_mailbox: boolean
  mailbox: string
  log_output_folder: string
  need_to_process: boolean
  enabled: boolean
  last_run_at?: string
  created_at?: string
  config: TaskConfig
}

export interface TaskViewModalProps {
  task: Task | null
  open: boolean
  onClose: () => void
  onDelete: (taskId: string) => void
  onSave: (task: Task) => void
}
```

